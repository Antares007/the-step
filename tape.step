// ABI parameters are passed by rgisters: a, b and c
// free registers are: d

goto bond downto: state locus

# move mutator
move  register a bond downto: data
point register a bond downto: lower state locus
goto  register b
# higher state locus
# state locus
move  register d register a 
point register a bond   upto: move mutator 
move  register b bond downto: data
point register c bond downto: move mutator
goto  register d
# data
1                
# move mutator
move  register a bond   upto: data
point register a bond downto: state locus
goto  register b


# move mutator
move  register a bond downto: data
point register a bond   upto: state locus
goto  register b
# state locus
move  register d register a 
point register a bond   upto: move mutator 
move  register b bond downto: data
point register c bond downto: move mutator
goto  register d
# data
2                
# move mutator
move  register a bond   upto: data
point register a bond downto: state locus
goto  register b


# move mutator
move  register a bond downto: data
point register a bond   upto: state locus
goto  register b
# lower state locus
# state locus
move  register d register a 
point register a bond   upto: move mutator 
move  register b bond downto: data
point register c bond downto: move mutator
goto  register d
# data
3                
# move mutator
move  register a bond   upto: data
point register a bond   upto: higher state locus
goto  register b
